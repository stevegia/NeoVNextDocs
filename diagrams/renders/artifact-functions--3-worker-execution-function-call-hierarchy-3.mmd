flowchart TD
    A["Go Supervisor pollLoop()\nsrc/gpu-supervisor/internal/supervisor/supervisor.go"] --> B
    B["db.ClaimNextJob()\n→ SELECT FOR UPDATE SKIP LOCKED\n→ UPDATE status='assigned'\nsrc/gpu-supervisor/internal/db/"] -->|job found| C
    C["processJob(job)"] --> D & E
    D["db.SetJobRunning()\n→ UPDATE status='running'"]
    E["db.GetInputManifest()\n→ SELECT cache_manifest WHERE direction='input'"] --> E2
    E2["filetransfer.Client.DownloadInputs()\n→ GET /api/cache/{jobId}/input/{key}\nvia Tailscale to desktop API"] --> F
    F["HTTP POST /handle to handler subprocess\n(or ComfyUI /prompt + /history)"] --> G
    G["filetransfer.Client.UploadOutputs()\n→ PUT /api/cache/{jobId}/output/{key}\nvia Tailscale to desktop API"] --> H
    H["db.RegisterOutputArtifact()\n→ INSERT cache_manifest (direction='output')"] --> I
    I["db.CompleteJob()\n→ UPDATE job_queue SET status='completed'"]

